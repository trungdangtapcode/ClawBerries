NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgres://clawberries:clawberries@localhost:5432/clawberries

# Redis
REDIS_URL=redis://localhost:6379

# Telegram (HR notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_HR_CHAT_ID=

# Gemini (CV parsing — Steps 3 & 4)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# LLM Synthesis — Step 7
# Provider: "gemini" (default) or "openai"
LLM_PROVIDER=gemini

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=

# TinyFish (browser automation — Steps 5 & 6)
# Base URL is hardcoded to https://agent.tinyfish.ai
TINYFISH_API_KEY=

# External APIs (optional)
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
SERPAPI_KEY=
BRIGHTDATA_API_KEY=


TINYFISH_API_KEY=


# minimal .env for dev: GEMINI_API_KEY, TINYFISH_API_KEY, DATABASE_URL, REDIS_URL